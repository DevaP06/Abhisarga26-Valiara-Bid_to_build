<%- include('layout/header') %>

<div class="row align-items-center mb-5">
  <div class="col-md-8">
    <h1 class="fw-bold tracking-tight display-5 text-gray-900">Portfolio Allocation</h1>
    <p class="text-secondary fs-5 mt-2">Distribute your remaining purse across your owned companies. You must allocate EXACTLY your total remaining purse.</p>
  </div>
  <div class="col-md-4 text-md-end mt-3 mt-md-0">
    <div class="card bg-dark text-white shadow-lg border-0 rounded-4">
      <div class="card-body p-4">
        <h6 class="text-uppercase text-gray-400 fw-bold mb-1">Target Purse to Allocate</h6>
        <h2 class="fw-bold mb-0 text-success" id="totalPurseDisplay">$<%= team.allocation_purse.toLocaleString() %></h2>
        <input type="hidden" id="maxPurse" value="<%= team.allocation_purse %>">
      </div>
    </div>
  </div>
</div>

<% if (hasAllocated) { %>
  <div class="alert alert-success shadow-sm rounded-4 border-0 py-4 px-5 text-center">
    <h4 class="fw-bold mb-2">Allocations Submitted!</h4>
    <p class="mb-0 fs-5">You have successfully allocated your funds. Wait for the admin to calculate the final scores.</p>
  </div>
<% } else if (ownedCompanies.length === 0) { %>
  <div class="alert alert-warning shadow-sm rounded-4 border-0 py-4 px-5 text-center">
    <h4 class="fw-bold text-dark">No Companies Owned</h4>
    <p class="text-dark">You cannot allocate funds because you did not win any companies in the auction.</p>
  </div>
<% } else { %>
  
  <div class="row">
    <div class="col-lg-8 mx-auto">
      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-5">
          <form action="/team/allocate" method="POST" id="allocationForm">
            
            <% ownedCompanies.forEach(company => { %>
              <div class="mb-4">
                <label class="form-label fw-bold fs-5 text-dark"><%= company.name %></label>
                <div class="row g-3">
                  <div class="col-sm-4">
                    <div class="input-group input-group-lg shadow-sm">
                      <input type="number" step="0.01" class="form-control border-0 bg-light pct-input" data-id="<%= company.id %>" placeholder="%" min="0" max="100">
                      <span class="input-group-text bg-light border-0 text-secondary fw-bold">%</span>
                    </div>
                  </div>
                  <div class="col-sm-8">
                    <div class="input-group input-group-lg shadow-sm">
                      <span class="input-group-text bg-light border-0 text-secondary fw-bold">$</span>
                      <input type="number" step="0.01" class="form-control border-0 bg-light allocation-input" name="company_<%= company.id %>" id="cash_<%= company.id %>" value="0" min="0" required>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>

            <hr class="my-5 text-muted">

            <div class="d-flex justify-content-between align-items-center mb-4 p-4 rounded-4" style="background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);">
              <span class="fs-5 fw-semibold text-secondary">Currently Allocated:</span>
              <span class="fs-3 fw-bold text-primary" id="allocatedSum">$0</span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 p-4 rounded-4" style="background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);">
              <span class="fs-5 fw-semibold text-secondary">Remaining to Allocate:</span>
              <span class="fs-3 fw-bold text-danger" id="remainingSum">$<%= team.allocation_purse.toLocaleString() %></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-sm py-3" id="submitBtn" disabled>
              Submit Final Allocation
            </button>
            <p class="text-center text-muted text-sm mt-3">Warning: This action cannot be undone.</p>
            
          </form>
        </div>
      </div>
    </div>
  </div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const inputs = document.querySelectorAll('.allocation-input');
    const pctInputs = document.querySelectorAll('.pct-input');
    const allocatedSumEl = document.getElementById('allocatedSum');
    const remainingSumEl = document.getElementById('remainingSum');
    const submitBtn = document.getElementById('submitBtn');
    const maxPurse = parseFloat(document.getElementById('maxPurse').value);

    function updateSums() {
      let sum = 0;
      inputs.forEach(input => {
        sum += parseFloat(input.value) || 0;
      });

      let remaining = maxPurse - sum;
      
      allocatedSumEl.textContent = '$' + sum.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 2});
      remainingSumEl.textContent = '$' + remaining.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 2});

      if (Math.abs(remaining) < 0.01) {
        remainingSumEl.className = 'fs-3 fw-bold text-success';
        submitBtn.disabled = false;
      } else {
        remainingSumEl.className = 'fs-3 fw-bold text-danger';
        submitBtn.disabled = true;
      }
    }

    pctInputs.forEach(pct => {
      pct.addEventListener('input', (e) => {
        const val = parseFloat(e.target.value) || 0;
        const id = e.target.getAttribute('data-id');
        const cashInput = document.getElementById('cash_' + id);
        cashInput.value = ((val / 100) * maxPurse).toFixed(2);
        updateSums();
      });
    });

    inputs.forEach(input => {
      input.addEventListener('input', (e) => {
        const val = parseFloat(e.target.value) || 0;
        const id = e.target.name.replace('company_', '');
        const pctInput = document.querySelector(`.pct-input[data-id="${id}"]`);
        if (pctInput && document.activeElement !== pctInput) {
          pctInput.value = maxPurse ? ((val / maxPurse) * 100).toFixed(2) : 0;
        }
        updateSums();
      });
    });
  });
</script>
<% } %>

<%- include('layout/footer') %>
