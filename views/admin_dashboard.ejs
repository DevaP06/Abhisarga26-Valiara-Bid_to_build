<%- include('layout/header') %>

<div class="row mb-4 align-items-center">
  <div class="col-md-6">
    <h1 class="fw-bold tracking-tight text-3xl">Admin Dashboard</h1>
    <p class="text-secondary text-sm">Manage companies, auction, phases, and results.</p>
  </div>
  <div class="col-md-6 text-md-end">
    <div class="badge bg-primary p-3 shadow-sm rounded-pill">
      <span class="fs-6">Current Phase: <strong class="text-uppercase"><%= systemControl.current_phase %></strong></span>
    </div>
  </div>
</div>

<div class="row g-4">
  <!-- Phase Control -->
  <div class="col-lg-3 col-md-6">
    <div class="card shadow-sm border-0 h-100 rounded-4">
      <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
        <h5 class="fw-bold"><i class="bi bi-gear-fill me-2"></i>Phase Control</h5>
      </div>
      <div class="card-body">
        <form action="/admin/set-phase" method="POST">
          <select name="phase" class="form-select mb-3 rounded-3" required>
            <option value="closed" <%= systemControl.current_phase === 'closed' ? 'selected' : '' %>>Closed</option>
            <option value="auction" <%= systemControl.current_phase === 'auction' ? 'selected' : '' %>>Auction</option>
            <option value="allocation" <%= systemControl.current_phase === 'allocation' ? 'selected' : '' %>>Allocation</option>
          </select>
          <button type="submit" class="btn btn-warning w-100 rounded-3 fw-semibold">Update Phase</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Create Team User -->
  <div class="col-lg-4 col-md-6">
    <div class="card shadow-sm border-0 h-100 rounded-4">
      <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
        <h5 class="fw-bold"><i class="bi bi-person-plus-fill me-2"></i>Create Team User</h5>
      </div>
      <div class="card-body">
        <form action="/admin/create-user" method="POST" class="row g-2">
          <div class="col-12">
            <input type="text" name="username" class="form-control rounded-3" placeholder="Username" required>
          </div>
          <div class="col-12">
            <input type="password" name="password" class="form-control rounded-3" placeholder="Password" required>
          </div>
          <div class="col-12 mt-3">
            <button type="submit" class="btn btn-dark w-100 rounded-3 fw-semibold">Create User</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Add Company -->
  <div class="col-lg-5 col-md-12">
    <div class="card shadow-sm border-0 h-100 rounded-4">
      <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
        <h5 class="fw-bold"><i class="bi bi-building-add me-2"></i>Add New Company</h5>
      </div>
      <div class="card-body">
        <form action="/admin/add-company" method="POST" enctype="multipart/form-data" class="row g-3">
          <div class="col-md-6">
            <input type="text" name="name" class="form-control rounded-3" placeholder="Company Name" required>
          </div>
          <div class="col-md-6">
            <input type="file" name="pdf_doc" class="form-control rounded-3" accept="application/pdf">
          </div>
          <div class="col-12">
            <textarea name="description" class="form-control rounded-3" placeholder="Description (Optional)" rows="2"></textarea>
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary rounded-3 fw-semibold px-4">Add Company</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mt-2">
  <!-- Live Auction Panel -->
  <div class="col-lg-6">
    <div class="card shadow-sm border-0 h-100 rounded-4" style="background: linear-gradient(135deg, #e0eafc, #cfdef3);">
      <div class="card-body p-4">
        <h4 class="fw-bold mb-4 text-primary">Live Auction Panel (Manual)</h4>
        <form action="/admin/assign-bid" method="POST">
          <div class="mb-3">
            <label class="form-label fw-semibold text-dark">Assign to Team</label>
            <select name="team_id" class="form-select rounded-3" required>
              <% teams.forEach(team => { %>
                <option value="<%= team.id %>"><%= team.team_name %> (Purse: $<%= team.purse_remaining.toLocaleString() %>)</option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold text-dark">Company Won</label>
            <select name="company_id" class="form-select rounded-3" required>
              <% companies.forEach(company => { %>
                <option value="<%= company.id %>"><%= company.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-4">
            <label class="form-label fw-semibold text-dark">Winning Bid Amount ($)</label>
            <input type="number" step="0.01" name="bid_amount" class="form-control rounded-3 form-control-lg" placeholder="e.g. 150000" required>
          </div>
          <button type="submit" class="btn btn-success w-100 rounded-3 fw-bold fs-5 shadow-sm py-2">Assign Company</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Purse Configuration -->
  <div class="col-lg-6">
    <div class="card shadow-sm border-0 h-100 rounded-4">
      <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
        <h5 class="fw-bold"><i class="bi bi-wallet2 me-2"></i>Purse Configuration</h5>
      </div>
      <div class="card-body p-4">
        <form action="/admin/update-default-purses" method="POST" class="mb-4">
          <div class="row g-2 mb-3">
            <div class="col-6">
              <label class="form-label text-sm text-muted">Global Bidding Purse</label>
              <input type="number" step="0.01" name="bidding_purse" class="form-control rounded-3" value="<%= systemControl.default_bidding_purse %>" required>
            </div>
            <div class="col-6">
              <label class="form-label text-sm text-muted">Global Allocation Purse</label>
              <input type="number" step="0.01" name="allocation_purse" class="form-control rounded-3" value="<%= systemControl.default_allocation_purse %>" required>
            </div>
          </div>
          <button type="submit" class="btn btn-outline-primary btn-sm rounded-3 w-100 fw-semibold">Save Global Defaults</button>
        </form>
        <hr class="text-muted">
        <h6 class="fw-bold mb-3"><i class="bi bi-person-fill-gear me-2"></i>Override Team Purses</h6>
        <form action="/admin/update-team-purse" method="POST">
          <select name="team_id" class="form-select mb-2 rounded-3" required>
            <option value="">Select Team to Override</option>
            <% teams.forEach(team => { %>
              <option value="<%= team.id %>"><%= team.team_name %> (Bid: $<%= team.purse_remaining.toLocaleString() %> | Alloc: $<%= (team.allocation_purse||0).toLocaleString() %>)</option>
            <% }) %>
          </select>
          <div class="row g-2 mb-3">
            <div class="col-6">
              <input type="number" step="0.01" name="bidding_purse" class="form-control form-control-sm rounded-3" placeholder="New Bidding Purse" required>
            </div>
            <div class="col-6">
              <input type="number" step="0.01" name="allocation_purse" class="form-control form-control-sm rounded-3" placeholder="New Alloc. Purse" required>
            </div>
          </div>
          <button type="submit" class="btn btn-warning w-100 rounded-3 fw-bold shadow-sm py-2 text-dark">Update Team Purses</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Broadcast Live Company -->
  <div class="col-lg-12">
    <div class="card shadow-sm border-0 rounded-4" style="background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);">
      <div class="card-body p-4">
        <h4 class="fw-bold mb-3 text-dark">Broadcast Live Company (Auction Phase)</h4>
        <form action="/admin/set-live-company" method="POST" class="row align-items-end g-3">
          <div class="col-md-9">
            <label class="form-label fw-semibold text-dark">Select Company to Show to Teams</label>
            <select name="company_id" class="form-select rounded-3 form-select-lg" required>
              <option value="none" <%= (!systemControl.live_company_id) ? 'selected' : '' %>>None (Clear Live Broadcast)</option>
              <% companies.forEach(company => { %>
                <option value="<%= company.id %>" <%= systemControl.live_company_id === company.id ? 'selected' : '' %>><%= company.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-3">
            <button type="submit" class="btn btn-dark w-100 rounded-3 fw-bold fs-5 shadow-sm py-2">Broadcast</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="row mt-5">
  <div class="col-12">
    <h4 class="fw-bold mb-3">Recent Auction Assignments</h4>
    <div class="table-responsive bg-white rounded-4 shadow-sm p-3 border-0">
      <table class="table table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>Company</th>
            <th>Winning Team</th>
            <th>Bid Amount</th>
            <th>Time</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (bids.length === 0) { %>
            <tr><td colspan="4" class="text-center text-muted py-4">No bids assigned yet.</td></tr>
          <% } else { %>
            <% bids.forEach(bid => { %>
              <tr>
                <td class="fw-semibold"><%= bid.company_name %></td>
                <td><span class="badge bg-secondary"><%= bid.team_name %></span></td>
                <td class="text-success fw-bold">$<%= bid.bid_amount.toLocaleString() %></td>
                <td class="text-muted text-sm"><%= new Date(bid.assigned_at).toLocaleString() %></td>
                <td>
                  <form action="/admin/revoke-bid" method="POST" class="m-0" onsubmit="return confirm('Are you sure you want to revoke this bid/assignment?');">
                    <input type="hidden" name="bid_id" value="<%= bid.id %>">
                    <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm rounded-pill fw-bold">Revoke</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="row g-4 mt-5">
  <div class="col-12"><h4 class="fw-bold text-danger border-bottom border-danger pb-2">Danger Zone (Entity Deletion)</h4></div>
  <!-- Delete Team -->
  <div class="col-lg-6">
    <div class="card shadow-sm border-danger border-opacity-50 h-100 rounded-4 bg-danger bg-opacity-10">
      <div class="card-body p-4">
        <h4 class="fw-bold mb-4 text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Team</h4>
        <form action="/admin/delete-team" method="POST" onsubmit="return confirm('WARNING: This will delete the team, their user account, all their bids, and their scores permanently! Are you absolutely sure?');">
          <div class="mb-3">
            <select name="team_id" class="form-select rounded-3 border-danger" required>
              <option value="">Select Team to Delete</option>
              <% teams.forEach(team => { %>
                <option value="<%= team.id %>"><%= team.team_name %></option>
              <% }) %>
            </select>
          </div>
          <button type="submit" class="btn btn-danger w-100 rounded-3 fw-bold shadow-sm py-2">Permanently Delete Team</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Delete Company -->
  <div class="col-lg-6">
    <div class="card shadow-sm border-danger border-opacity-50 h-100 rounded-4 bg-danger bg-opacity-10">
      <div class="card-body p-4">
        <h4 class="fw-bold mb-4 text-danger"><i class="bi bi-trash-fill me-2"></i>Delete Company</h4>
        <form action="/admin/delete-company" method="POST" onsubmit="return confirm('WARNING: This will delete the company, any bids placed on it, and results permanently! Are you absolutely sure?');">
          <div class="mb-3">
            <select name="company_id" class="form-select rounded-3 border-danger" required>
              <option value="">Select Company to Delete</option>
              <% companies.forEach(company => { %>
                <option value="<%= company.id %>"><%= company.name %></option>
              <% }) %>
            </select>
          </div>
          <button type="submit" class="btn btn-danger w-100 rounded-3 fw-bold shadow-sm py-2">Permanently Delete Company</button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('layout/footer') %>
