<%- include('layout/header') %>

<div class="row mb-5 justify-content-center text-center">
  <div class="col-md-8">
    <h1 class="fw-bold tracking-tight display-4 text-gray-900 mb-3">Team Portfolios</h1>
    <p class="text-secondary fs-5">Consolidated summary of all team holdings and allocations for manual grading.</p>
  </div>
</div>

<div class="row justify-content-center g-4">
  <% if (!teams || teams.length === 0) { %>
    <div class="col-12 text-center text-muted py-5">
      <i class="bi bi-folder-x display-1 mb-3"></i>
      <h4 class="text-muted fw-semibold">No teams registered yet.</h4>
    </div>
  <% } else { %>
    <% teams.forEach(team => { %>
      <div class="col-lg-6">
        <div class="card shadow-sm border-0 rounded-4 h-100">
          <div class="card-header bg-dark text-white rounded-top-4 py-3 d-flex justify-content-between align-items-center border-0">
            <h5 class="fw-bold mb-0 text-white"><i class="bi bi-people-fill me-2"></i><%= team.team_name %></h5>
          </div>
          <div class="card-body p-4">
            <div class="row mb-4 text-center g-3">
              <div class="col-6">
                <div class="p-3 bg-light rounded-4 h-100">
                  <div class="text-sm text-muted fw-semibold text-uppercase mb-1">Bidded Assets</div>
                  <div class="fs-4 fw-bold text-primary"><%= team.bids.length %> Companies</div>
                  <div class="text-xs text-muted mt-1">Total Spent: $<%= team.total_bidded.toLocaleString() %></div>
                </div>
              </div>
              <div class="col-6">
                <div class="p-3 bg-light rounded-4 h-100">
                  <div class="text-sm text-muted fw-semibold text-uppercase mb-1">Allocated Funds</div>
                  <div class="fs-4 fw-bold text-success">$<%= team.total_allocated.toLocaleString() %></div>
                </div>
              </div>
            </div>

            <h6 class="fw-bold text-secondary border-bottom border-2 pb-2 mb-3">Portfolio Details</h6>
            <% if (team.bids.length === 0) { %>
              <p class="text-muted text-center py-4 bg-light rounded-3">No companies acquired yet.</p>
            <% } else { %>
              <ul class="list-group list-group-flush">
                <% team.bids.forEach(bid => { %>
                  <% 
                    const alloc = team.allocations.find(a => a.company_name === bid.company_name); 
                  %>
                  <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                    <div>
                      <span class="fw-bold text-dark fs-5"><%= bid.company_name %></span>
                      <div class="text-sm text-muted fw-semibold">Won for $<%= bid.bid_amount.toLocaleString() %></div>
                    </div>
                    <% if (alloc) { %>
                      <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2 fs-6">Allocated: $<%= alloc.allocated_amount.toLocaleString() %></span>
                    <% } else { %>
                      <span class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-pill px-3 py-2">Pending Allocation</span>
                    <% } %>
                  </li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>

<%- include('layout/footer') %>
